<idea-plugin>
    <id>net.mehvahdjukaar.candlelight</id>
    <name>Candlelight Idea</name>
    <vendor url="https://github.com/MehVahdJukaar/architectury-idea-plugin">Candlelight</vendor>

    <description><![CDATA[
    Companion plugin for the Candlelight Gradle plugin.
    ]]></description>

    <extensions defaultExtensionNs="org.jetbrains.kotlin">
        <supportsKotlinPluginMode supportsK2="true"/>
    </extensions>

    <!-- please see https://www.jetbrains.org/intellij/sdk/docs/basics/getting_started/plugin_compatibility.html
         on how to target different products -->
    <depends>com.intellij.modules.java</depends>
    <depends>org.jetbrains.kotlin</depends>

    <extensions defaultExtensionNs="com.intellij">

        <!--
           <postStartupActivity implementation="net.mehvahdjukaar.flash.FlashPlugin"/>
  -->


        <editorTabTitleProvider implementation="net.mehvahdjukaar.candle.icon.ModuleAwareTabTitleProvider"/>


        <codeInsight.lineMarkerProvider language="JAVA"
                                        implementationClass="net.mehvahdjukaar.candle.gutter.CommonMethodLineMarkerProvider"/>
        <codeInsight.lineMarkerProvider language="JAVA"
                                        implementationClass="net.mehvahdjukaar.candle.gutter.PlatformMethodLineMarkerProvider"/>
        <codeInsight.lineMarkerProvider language="JAVA"
                                        implementationClass="net.mehvahdjukaar.candle.gutter.VirtualOverrideLineMarkerProvider"/>

        <localInspection language="JAVA"
                         shortName="VirtualOverride"
                         enabledByDefault="true"
                         level="ERROR"
                         implementationClass="net.mehvahdjukaar.candle.inspection.VirtualOverrideInspection"
                         key="inspection.virtual.override.display.name" bundle="messages.Candle" groupKey="group.key"/>

        <localInspection language="JAVA"
                         enabledByDefault="true"
                         level="WARNING"
                         implementationClass="net.mehvahdjukaar.candle.inspection.UnimplementedPlatformImplInspection"
                         key="inspection.unimplemented.platform.impl.display.name" bundle="messages.Candle"
                         groupKey="group.key"/>

        <localInspection language="JAVA"
                         shortName="ExpectPlatformBody"
                         enabledByDefault="true"
                         level="WARNING"
                         implementationClass="net.mehvahdjukaar.candle.inspection.PlatformImplBodyInspection"
                         key="inspection.expect.platform.body.display.name" bundle="messages.Candle"
                         groupKey="group.key"/>

        <completion.contributor
            language="JAVA"
            implementationClass="net.mehvahdjukaar.candle.contributor.VirtualOverrideCompletionContributor"/>

        <implicitUsageProvider implementation="net.mehvahdjukaar.candle.insight.PlatformImplImplicitUsageProvider"/>
        <implicitUsageProvider
            implementation="net.mehvahdjukaar.candle.insight.VirtualPlatformOverrideImplicitUsageProvider"/>
    </extensions>

    <actions>
        <!-- Add your actions here -->
    </actions>
</idea-plugin>
